# DeepSeek Eyes — 必填
ARK_API_KEY=sk-your-ark-api-key

# 视觉模型（可选）
# VISION_MODEL=doubao-seed-1-6-vision-250815
# VISION_TIMEOUT=120
# VISION_FAIL_MODE=placeholder

# 代理端口（可选）
# PROXY_PORT=8788

# 缓存（可选。警告：磁盘缓存包含图片描述/OCR文字，等同截图内容）
# CACHE_PERSIST_ENABLED=true
# CACHE_TTL_HOURS=168
# CACHE_MAX_ENTRIES=500

# 安全（可选）
# MAX_IMAGE_RAW_BYTES=10485760
# MAX_REQUEST_BODY_BYTES=33554432

# 调试（可选。警告：DEBUG 响应含完整 prompt/OCR，不要在 launchd 开启）
# DEEPSEEK_EYES_DEBUG=1
# DEEPSEEK_EYES_FAKE_VISION=1
